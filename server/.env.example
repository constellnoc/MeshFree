# Prisma uses this SQLite database file in production.
DATABASE_URL="file:./prisma/prod.db"

# Replace with a long random secret generated on the server.
JWT_SECRET="replace-this-with-a-random-secret"

# Backend listening port.
PORT=3001

# Runtime environment.
NODE_ENV="production"

# Comma-separated origins allowed by CORS in production.
CORS_ALLOWED_ORIGINS="https://yukiho.site,https://www.yukiho.site"

# First-time admin initialization.
ADMIN_SEED_USERNAME="mano"
ADMIN_SEED_PASSWORD="replace-this-with-a-strong-password"
