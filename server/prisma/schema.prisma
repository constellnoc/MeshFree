// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

enum SourceFormat {
  obj
  fbx
  dae
  blend
  glb
  unknown
}

enum PreviewConversionStatus {
  not_attempted
  success
  warning
  failed
}

enum TagScopeLevel {
  broad
  medium
  specific
}

enum RawTagStatus {
  pending
  resolved
  ignored
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Submission {
  id                      Int                     @id @default(autoincrement())
  title                   String
  description             String
  contact                 String
  coverImagePath          String
  modelZipPath            String
  previewModelPath        String?
  sourceFormat            SourceFormat            @default(unknown)
  previewConversionStatus PreviewConversionStatus @default(not_attempted)
  previewConversionMessage String?
  isPreviewEnabled        Boolean                 @default(true)
  isPublicVisible         Boolean                 @default(false)
  hasMissingTextures      Boolean                 @default(false)
  status                  SubmissionStatus        @default(pending)
  rejectReason            String?
  createdAt               DateTime                @default(now())
  reviewedAt              DateTime?
  updatedAt               DateTime                @updatedAt
  tags                    SubmissionTag[]
  rawTags                 SubmissionRawTag[]
}

model Tag {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  scopeLevel       TagScopeLevel      @default(medium)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  submissions      SubmissionTag[]
  translations     TagTranslation[]
  aliases          TagAlias[]
  resolvedRawTags  SubmissionRawTag[] @relation("ResolvedRawTag")
}

model SubmissionTag {
  submissionId Int
  tagId        Int
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([submissionId, tagId])
  @@index([tagId])
}

model TagTranslation {
  id                    Int      @id @default(autoincrement())
  tagId                 Int
  locale                String
  displayName           String
  normalizedDisplayName String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  tag                   Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale, normalizedDisplayName])
}

model TagAlias {
  id              Int      @id @default(autoincrement())
  tagId           Int
  locale          String
  value           String
  normalizedValue String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tag             Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([locale, normalizedValue])
  @@index([tagId])
}

model SubmissionRawTag {
  id              Int          @id @default(autoincrement())
  submissionId    Int
  resolvedTagId   Int?
  value           String
  normalizedValue String
  status          RawTagStatus @default(pending)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  submission      Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  resolvedTag     Tag?         @relation("ResolvedRawTag", fields: [resolvedTagId], references: [id], onDelete: SetNull)

  @@index([submissionId, status])
  @@index([normalizedValue])
}
